meta {
  name: login
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/login
  body: json
  auth: inherit
}

body:json {
  {
    "email": "borrower1@test.com",
    "password": "Password123!"
  }
}

vars:post-response {
  userId: {{res.body.data.user.id}}
  sessionToken: {{res.body.data.token}}
}

settings {
  encodeUrl: true
  timeout: 0
}
